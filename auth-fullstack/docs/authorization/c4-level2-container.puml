@startuml C4 - Level 2 - Container Diagram (Authorization)

title C4 Level 2 - Container Diagram (Authorization)

actor "User" as user

node "Client\n[React + Vite]\nport 5173" as client {
}

node "Backend\n[Express.js]\nport 3001" as backend {
}

database "In-Memory Store\n[JS Object]\nusers, refreshTokens" as db

user --> client : opens browser
client --> backend : POST /login\n{ email, password }
backend --> client : { accessToken }\n+ Set-Cookie: refreshToken (httpOnly)
client --> backend : GET /protected\nAuthorization: Bearer <accessToken>
client --> backend : POST /refresh-tokens\nCookie: refreshToken
backend --> db : read/write users\nread/write refreshTokens

@enduml
